{
  "title": "factory-ems · SLO Overview",
  "uid": "slo-overview",
  "schemaVersion": 39,
  "editable": false,
  "tags": ["factory-ems", "observability", "slo"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"factory-ems\"}, instance)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "可用性 (30d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "ems:slo:availability:sli_30d", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          },
          "min": 0.95,
          "max": 1
        }
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API p99 (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "ems:slo:latency:p99_5m", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "数据新鲜度 (max lag)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "ems:slo:freshness:max_lag_seconds", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "调度漂移 (max abs)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [{ "expr": "ems:slo:scheduler_drift:max_seconds", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "v1 占位",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "可用性错误预算剩余",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [{ "expr": "ems:slo:availability:error_budget_remaining", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": true, "showThresholdMarkers": true }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "可用性 30 天趋势",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [{ "expr": "ems:slo:availability:sli_30d", "refId": "A", "legendFormat": "SLI" }],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0.95, "max": 1 }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "可用性燃烧率 (1h vs 6h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "(1 - avg_over_time(up{job=\"factory-ems\"}[1h])) / 0.005", "refId": "A", "legendFormat": "1h burn" },
        { "expr": "(1 - avg_over_time(up{job=\"factory-ems\"}[6h])) / 0.005", "refId": "B", "legendFormat": "6h burn" },
        { "expr": "vector(14.4)", "refId": "C", "legendFormat": "fast threshold (14.4×)" },
        { "expr": "vector(6)", "refId": "D", "legendFormat": "slow threshold (6×)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "当前 firing 告警",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true },
            "indexByName": { "alertname": 0, "severity": 1, "team": 2, "instance": 3 }
          }
        }
      ]
    }
  ]
}
