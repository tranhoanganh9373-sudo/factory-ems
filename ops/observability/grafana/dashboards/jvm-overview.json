{
  "title": "factory-ems · JVM",
  "uid": "jvm-overview",
  "schemaVersion": 39,
  "editable": false,
  "tags": ["factory-ems", "observability", "jvm"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"factory-ems\"}, instance)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Heap 使用率",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", instance=~\"$instance\"}) / sum(jvm_memory_max_bytes{area=\"heap\", instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "活跃线程数",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(jvm_threads_live_threads{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "已加载类数",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(jvm_classes_loaded_classes{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GC 停顿率 (s/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Heap used vs max",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\", instance=~\"$instance\"})",
          "legendFormat": "used {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (jvm_memory_max_bytes{area=\"heap\", instance=~\"$instance\"})",
          "legendFormat": "max {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Non-heap used vs max",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"nonheap\", instance=~\"$instance\"})",
          "legendFormat": "used {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (jvm_memory_max_bytes{area=\"nonheap\", instance=~\"$instance\"})",
          "legendFormat": "max {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC 停顿时间 (按 gc)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (gc) (rate(jvm_gc_pause_seconds_sum{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{gc}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GC 次数速率 (按 gc)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (gc) (rate(jvm_gc_pause_seconds_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{gc}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "线程数 (live / daemon / peak)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_threads_live_threads{instance=~\"$instance\"})",
          "legendFormat": "live {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (jvm_threads_daemon_threads{instance=~\"$instance\"})",
          "legendFormat": "daemon {{instance}}",
          "refId": "B"
        },
        {
          "expr": "sum by (instance) (jvm_threads_peak_threads{instance=~\"$instance\"})",
          "legendFormat": "peak {{instance}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Hikari 连接池 (active / idle / max)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (pool) (hikaricp_connections_active{instance=~\"$instance\"})",
          "legendFormat": "active {{pool}}",
          "refId": "A"
        },
        {
          "expr": "sum by (pool) (hikaricp_connections_idle{instance=~\"$instance\"})",
          "legendFormat": "idle {{pool}}",
          "refId": "B"
        },
        {
          "expr": "sum by (pool) (hikaricp_connections_max{instance=~\"$instance\"})",
          "legendFormat": "max {{pool}}",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Tomcat 活跃会话",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (tomcat_sessions_active_current_sessions{instance=~\"$instance\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Logback 日志事件 (按级别)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (level) (rate(logback_events_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
