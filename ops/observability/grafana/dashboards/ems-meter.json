{
  "title": "factory-ems · Meter",
  "uid": "ems-meter",
  "schemaVersion": 39,
  "editable": false,
  "tags": ["factory-ems", "observability", "meter"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"factory-ems\"}, instance)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "当前最大 lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "max(ems_meter_reading_lag_seconds{job=\"factory-ems\", instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "入库速率 (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(ems_meter_reading_insert_rate_total{job=\"factory-ems\", instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "24h 丢弃总数",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(increase(ems_meter_reading_dropped_total{job=\"factory-ems\", instance=~\"$instance\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Lag vs SLO (max 300s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "max(ems_meter_reading_lag_seconds{job=\"factory-ems\", instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 300,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": true, "showThresholdMarkers": true }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "入库速率 by energy_type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (energy_type) (rate(ems_meter_reading_insert_rate_total{job=\"factory-ems\", instance=~\"$instance\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{energy_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "丢弃 by reason",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(ems_meter_reading_dropped_total{job=\"factory-ems\", instance=~\"$instance\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Lag 30 天趋势",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "max(ems_meter_reading_lag_seconds{job=\"factory-ems\", instance=~\"$instance\"})",
          "refId": "A",
          "legendFormat": "max lag"
        },
        {
          "expr": "vector(300)",
          "refId": "B",
          "legendFormat": "SLO target (300s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top 10 能源类型入库 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (energy_type) (increase(ems_meter_reading_insert_rate_total{job=\"factory-ems\", instance=~\"$instance\"}[24h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": { "energy_type": 0, "Value": 1 },
            "renameByName": { "Value": "rows inserted (24h)" }
          }
        }
      ]
    }
  ]
}
