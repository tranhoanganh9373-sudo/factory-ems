# ============================================================================
# factory-ems Observability Stack — environment variables
# ============================================================================
# 按需复制为 .env.obs 后在本机填写。生产环境请使用 secret-manager 注入。

# ----- Grafana ------------------------------------------------------------
# 必填。首次启动建议运行 ./scripts/grafana-init.sh 自动生成强随机密码。
OBS_GRAFANA_ADMIN_USER=admin
OBS_GRAFANA_ADMIN_PASSWORD=

# ----- 数据保留期 ----------------------------------------------------------
# 可选；不填走默认值。
OBS_PROMETHEUS_RETENTION=30d
OBS_LOKI_RETENTION=336h          # 14 天
OBS_TEMPO_RETENTION=72h          # 3 天

# ----- Email 告警通道（可选） ---------------------------------------------
# 任一字段为空 → email receiver 被 Alertmanager 静默跳过，不阻止启动。
OBS_SMTP_HOST=
OBS_SMTP_USER=
OBS_SMTP_PASSWORD=
OBS_ALERT_RECEIVER_EMAIL=

# ----- 钉钉机器人（可选） -------------------------------------------------
# 留空 → /dingtalk receiver 跳过。建议同时配置 SECRET 启用加签。
OBS_DINGTALK_WEBHOOK=
OBS_DINGTALK_SECRET=

# ----- 企业微信机器人（可选） ---------------------------------------------
# 留空 → /wechat receiver 跳过。
OBS_WECHAT_WEBHOOK=

# ----- 通用 webhook（可选） -----------------------------------------------
# 接客户内部 IT 工单系统等。留空 → 跳过。
OBS_GENERIC_WEBHOOK=

# ----- Docker network ------------------------------------------------------
# 可选；产品栈与观测栈共享的 docker network 名称。脚本会幂等创建。
OBS_NETWORK_NAME=ems-net
